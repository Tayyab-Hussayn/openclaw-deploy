# OpenClaw Environment Config
# DO NOT use ~ here — Docker Compose does not expand it in volume paths.
# setup.sh writes the correct absolute paths automatically.
# Only edit this manually if you know what you're doing.

OPENCLAW_CONFIG_DIR=/home/YOUR_USERNAME/.openclaw
OPENCLAW_WORKSPACE_DIR=/path/to/openclaw-deploy/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
